  "sensitive_fields": {
    "salary": {
      "description": "Employee salary",
      "visibility": [
        "executive",
        "hr",
        "finance",
        "manager"
      ],
      "audit_log": true
    },
    "ssn": {
      "description": "Social Security Number",
      "visibility": [
        "hr",
        "finance"
      ],
      "audit_log": true,
      "redact": true
    },
    "address": {
      "description": "Home address",
      "visibility": [
        "hr",
        "executive"
      ],
      "audit_log": true
    },
    "compensation": {
      "description": "Salary, bonus, stock options",
      "visibility": [
        "executive",
        "finance"
      ],
      "audit_log": true
    },
    "performance_review": {
      "description": "Performance ratings",
      "visibility": [
        "manager",
        "hr",
        "executive"
      ],
      "audit_log": true
    }
  },
  "document_access": {
    "Public": ["engineer", "manager", "hr", "finance", "executive"],
    "Internal": ["engineer", "manager", "hr", "finance", "executive"],
    "Confidential": ["manager", "hr", "finance", "executive"],
    "Restricted": ["hr", "executive"]
